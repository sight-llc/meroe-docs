# URL the FastAPI/Spring Boot backend serves its OpenAPI spec from.
# Used by `npm run gen-api` to regenerate content/docs/api-reference/.
# Local dev example:   http://localhost:8080/v3/api-docs
# Deployed example:    https://api.nombavault.dev/v3/api-docs
NEXT_PUBLIC_API_BASE_URL=
